---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<span>&copy; {year} Nishat Shahriyar</span>
		<div class="links">
			<a href="https://twitter.com/rednishat" target="_blank" rel="noopener">X</a>
			<span class="sep">&middot;</span>
			<a href="https://www.linkedin.com/in/nishatshahriyar/" target="_blank" rel="noopener">LinkedIn</a>
			<span class="sep">&middot;</span>
			<a href="/rss.xml" class="rss">RSS</a>
				<span class="sep">&middot;</span>
				<a href="/sitemap-index.xml">Sitemap</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 2rem 1.5rem;
		border-top: 1px solid var(--border);
		margin-top: auto;
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 680px;
		margin: 0 auto;
		font-size: 0.875rem;
		color: var(--text-muted);
		gap: 1rem;
	}

	.links {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.links a {
		color: var(--text-muted);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.15s;
	}

	.links a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.sep {
		color: var(--border);
		user-select: none;
	}

	.rss {
		letter-spacing: 0.05em;
		font-size: 0.8rem;
		text-transform: uppercase;
	}

	@media (max-width: 480px) {
		.footer-inner {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75rem;
		}
	}
</style>
